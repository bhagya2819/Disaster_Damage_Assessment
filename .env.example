# Copy to .env and fill in. .env is gitignored.

# --- Google Earth Engine (optional: user-auth `earthengine authenticate` also works) ---
GEE_SERVICE_ACCOUNT_EMAIL=
GEE_SERVICE_ACCOUNT_JSON=  # path to key.json

# --- Copernicus Open Access Hub (Sentinel-1/2 fallback via sentinelsat) ---
COPERNICUS_USER=
COPERNICUS_PASSWORD=

# --- Weights & Biases (experiment tracking) ---
WANDB_API_KEY=
WANDB_PROJECT=dda-flood
WANDB_ENTITY=

# --- Runtime flags ---
DDA_DATA_DIR=./data
DDA_MODEL_DIR=./models
DDA_DEVICE=cuda   # or cpu
DDA_LOG_LEVEL=INFO
