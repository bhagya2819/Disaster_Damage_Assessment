# -------- Data (do not commit large geospatial data) --------
data/raw/**
data/processed/**
data/gt/**
data/external/**
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/gt/.gitkeep
!data/external/.gitkeep
*.tif
*.tiff
*.TIF
*.TIFF
*.jp2
*.nc
*.hdf
*.h5
*.zarr
*.shp
*.shx
*.dbf
*.prj
*.cpg
*.qpj
*.gpkg
*.geojson
!configs/**/*.geojson
!tests/fixtures/**

# -------- Model artefacts (root-only; do not swallow src/models/) --------
/models/
/checkpoints/

# -------- App bundled sample chips — commit the tiny .npz snapshots --------
!app/sample_chips/**/*.npz
!app/sample_chips/manifest.json
*.pt
*.pth
*.ckpt
*.onnx
*.pkl
*.joblib
lightning_logs/
mlruns/

# -------- Reports build artefacts --------
reports/figures/*.png
reports/figures/*.jpg
reports/figures/*.pdf
reports/figures/*.svg
!reports/figures/.gitkeep
*.aux
*.log
*.out
*.toc
*.bbl
*.blg
*.synctex.gz

# -------- Streamlit --------
.streamlit/secrets.toml

# -------- Misc --------
*.zip
*.tar
*.tar.gz
*.rar
